/* ============================================================
 * allostatic_dag.dot
 * Directed graph for the Allostatic Theory of Oxytocin
 *
 * Colour conventions
 *   Purple  (#9970ab) : OXT input Ω
 *   Blue    (#4393c3) : OXT-dependent parameter functions
 *                       σ(Ω), α(Ω), w(Ω), γ(Ω) — solid border (verbal theory)
 *                       κ(Ω) — dashed border (formalisation extension, tested as P8)
 *   Orange  (#d6600a) : Environmental inputs s(t+h) and s(t)
 *   Grey    (#555555) : Computation cascade nodes and edges
 *   Teal    (#2e8b8b) : Body state y(t)
 *   Red     (#c0392b) : Output metrics f(t), L(t), E
 *
 * Edge styles
 *   solid  : cascade flow and output aggregation
 *   dashed : OXT-modulated parameter influence on cascade
 *   dotted : environmental inputs
 *
 * Render with Graphviz:
 *   dot -Tpdf allostatic_dag.dot -o allostatic_dag.pdf
 *   dot -Tpng allostatic_dag.dot -o allostatic_dag.png
 *   dot -Tsvg allostatic_dag.dot -o allostatic_dag.svg
 *
 * Or in R via DiagrammeR:
 *   DiagrammeR::grViz(readLines("allostatic_dag.dot"))
 * ============================================================ */

digraph allostatic_theory {

  graph [
    rankdir  = LR
    fontname = "Helvetica"
    fontsize = 9
    bgcolor  = white
    splines  = ortho
    nodesep  = 0.4
    ranksep  = 0.6
  ]

  node [
    shape    = rectangle
    style    = filled
    fontname = "Helvetica"
    fontsize = 9
    margin   = "0.12,0.06"
  ]

  edge [
    fontname = "Helvetica"
    fontsize = 8
    arrowsize = 0.7
  ]

  /* ── Zone 1: OXT input ──────────────────────────────────────── */
  subgraph cluster_oxt {
    label     = "OXT input"
    fontcolor = "grey55"
    fontsize  = 8
    style     = filled
    fillcolor = "#f5eefa"
    color     = "#f5eefa"

    oxt [
      label     = "Ω\nOXT level"
      fillcolor = "#e8d5f0"
      color     = "#9970ab"
      penwidth  = 1.5
      fontcolor = "#9970ab"
    ]
  }

  /* ── Zone 2: OXT-dependent parameters ──────────────────────── */
  subgraph cluster_params {
    label     = "Parameters"
    fontcolor = "grey55"
    fontsize  = 8
    style     = filled
    fillcolor = "#ebf3fb"
    color     = "#ebf3fb"

    /* Four verbal-theory parameters — solid border */
    sig [
      label     = "σ(Ω)\nsensing noise"
      fillcolor = "#dbeafe"
      color     = "#4393c3"
      penwidth  = 1.2
      fontcolor = "#4393c3"
    ]
    alp [
      label     = "α(Ω)\nlearning rate"
      fillcolor = "#dbeafe"
      color     = "#4393c3"
      penwidth  = 1.2
      fontcolor = "#4393c3"
    ]
    w [
      label     = "w(Ω)\nprior weight"
      fillcolor = "#dbeafe"
      color     = "#4393c3"
      penwidth  = 1.2
      fontcolor = "#4393c3"
    ]
    gam [
      label     = "γ(Ω)\nresponse gain"
      fillcolor = "#dbeafe"
      color     = "#4393c3"
      penwidth  = 1.2
      fontcolor = "#4393c3"
    ]

    /* κ(Ω): formalisation extension beyond verbal theory — dashed border */
    kap [
      label     = "κ(Ω)\nefferent coupling"
      fillcolor = "#dbeafe"
      color     = "#4393c3"
      penwidth  = 1.2
      style     = "filled,dashed"
      fontcolor = "#4393c3"
    ]

    /* Fix top-to-bottom ordering within the parameter column */
    { rank = same; sig; alp; w; gam; kap }
  }

  /* ── Zone 3: Computation cascade (per time-step t) ─────────── */
  subgraph cluster_cascade {
    label     = "Computation cascade (per time-step t)"
    fontcolor = "grey55"
    fontsize  = 8
    style     = filled
    fillcolor = "#f8f8f8"
    color     = "#f8f8f8"

    /* Environmental input nodes (orange) */
    cue [
      label     = "s(t+h)\npred. cue"
      fillcolor = "#fce8d0"
      color     = "#d6600a"
      penwidth  = 1.0
      fontcolor = "#d6600a"
    ]
    env [
      label     = "s(t)\ntrue state"
      fillcolor = "#fce8d0"
      color     = "#d6600a"
      penwidth  = 1.0
      fontcolor = "#d6600a"
    ]

    /* Cascade state nodes (grey) */
    obs [
      label     = "ô(t)\nobservation"
      fillcolor = "#eeeeee"
      color     = "#555555"
      penwidth  = 1.0
      fontcolor = "#555555"
    ]
    bel [
      label     = "b(t)\nbelief"
      fillcolor = "#eeeeee"
      color     = "#555555"
      penwidth  = 1.0
      fontcolor = "#555555"
    ]
    pre [
      label     = "p(t)\nprediction"
      fillcolor = "#eeeeee"
      color     = "#555555"
      penwidth  = 1.0
      fontcolor = "#555555"
    ]
    xst [
      label     = "x(t)\nset-point"
      fillcolor = "#eeeeee"
      color     = "#555555"
      penwidth  = 1.0
      fontcolor = "#555555"
    ]

    /* Body state node (teal) — driven by passive drift δ and efferent coupling κ(Ω) */
    ybd [
      label     = "y(t)\nbody state"
      fillcolor = "#d4eeee"
      color     = "#2e8b8b"
      penwidth  = 1.4
      fontcolor = "#2e8b8b"
    ]

    { rank = same; cue; env }
    { rank = same; obs; bel }
  }

  /* ── Zone 4: Output metrics ─────────────────────────────────── */
  subgraph cluster_output {
    label     = "Output"
    fontcolor = "grey55"
    fontsize  = 8
    style     = filled
    fillcolor = "#fef2f0"
    color     = "#fef2f0"

    fit [
      label     = "f(t)\nfitness\n1 − |x(t) − s(t)|"
      fillcolor = "#fcd8d4"
      color     = "#c0392b"
      penwidth  = 1.2
      fontcolor = "#c0392b"
    ]
    loa [
      label     = "L(t)\nload\n|y(t) − x(t)|"
      fillcolor = "#fcd8d4"
      color     = "#c0392b"
      penwidth  = 1.2
      fontcolor = "#c0392b"
    ]
    eff [
      label     = "E\nefficiency\nmean(f) / mean(L)"
      fillcolor = "#fcd8d4"
      color     = "#c0392b"
      penwidth  = 1.8
      fontcolor = "#c0392b"
    ]

    { rank = same; fit; loa }
  }

  /* ═══════════════════════════════════════════════════════════════
   * EDGES
   * ═══════════════════════════════════════════════════════════════ */

  /* ── Ω → parameters (purple, solid) ──────────────────────────── */
  oxt -> sig [ color = "#9970ab"  penwidth = 1.2 ]
  oxt -> alp [ color = "#9970ab"  penwidth = 1.2 ]
  oxt -> w   [ color = "#9970ab"  penwidth = 1.2 ]
  oxt -> gam [ color = "#9970ab"  penwidth = 1.2 ]
  oxt -> kap [ color = "#9970ab"  penwidth = 1.2 ]

  /* ── Parameters → cascade (blue, dashed) ─────────────────────── */
  /* σ(Ω) modulates sensing: adds noise to the predictive cue        */
  sig -> obs [ color = "#4393c3"  style = dashed  penwidth = 0.9 ]
  /* α(Ω) controls the belief update rate                            */
  alp -> bel [ color = "#4393c3"  style = dashed  penwidth = 0.9 ]
  /* w(Ω) weights prior belief vs. current observation in prediction */
  w   -> pre [ color = "#4393c3"  style = dashed  penwidth = 0.9 ]
  /* γ(Ω) controls the set-point adjustment rate toward prediction   */
  gam -> xst [ color = "#4393c3"  style = dashed  penwidth = 0.9 ]
  /* κ(Ω) pulls body state toward set-point (efferent coupling)      */
  kap -> ybd [ color = "#4393c3"  style = dashed  penwidth = 0.9 ]

  /* ── Environmental inputs (orange, dotted) ───────────────────── */
  /* Predictive cue s(t+h) feeds the noisy observation               */
  cue -> obs [ color = "#d6600a"  style = dotted  penwidth = 1.2 ]
  /* True state s(t) drives passive body-state drift (rate δ = 0.15) */
  env -> ybd [ color = "#d6600a"  style = dotted  penwidth = 0.9 ]
  /* True state s(t) enters fitness calculation                       */
  env -> fit [ color = "#d6600a"  style = dotted  penwidth = 0.9 ]

  /* ── Cascade flow (grey, solid) ──────────────────────────────── */
  obs -> bel [ color = "#555555"  penwidth = 1.2 ]
  obs -> pre [ color = "#555555"  penwidth = 1.2 ]
  bel -> pre [ color = "#555555"  penwidth = 1.2 ]
  pre -> xst [ color = "#555555"  penwidth = 1.2 ]
  xst -> fit [ color = "#555555"  penwidth = 1.2 ]
  xst -> loa [ color = "#555555"  penwidth = 1.2 ]

  /* ── Body state → load (teal, solid) ─────────────────────────── */
  ybd -> loa [ color = "#2e8b8b"  penwidth = 1.2 ]

  /* ── Output aggregation (red, solid) ─────────────────────────── */
  fit -> eff [ color = "#c0392b"  penwidth = 1.2 ]
  loa -> eff [ color = "#c0392b"  penwidth = 1.2 ]
}
